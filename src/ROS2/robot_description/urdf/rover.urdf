<?xml version="1.0"?>
<robot name="wave_rover">

  <link name="base_link"/>

  <link name="laser">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.03"/>
      </geometry>
    </visual>
  </link>

  <joint name="base_to_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.0 0.0 0.1685" rpy="0 0 0"/>
  </joint>

</robot>
